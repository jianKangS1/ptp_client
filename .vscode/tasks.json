{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "NTP: 安装依赖 (pip editable)",
      "type": "shell",
      "command": "pip install -e \".[dev]\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-Command"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "NTP: 校验/预览配置",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/scripts/configure-ntp-client.ps1\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "NTP: 命令行客户端（单次查询后退出）",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/scripts/start-ntp-client.ps1\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "NTP Web: 安装依赖 (pip web)",
      "type": "shell",
      "command": "pip install -e \".[web]\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-Command"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "NTP Web: 启动控制台（保持运行，浏览器打开 8765）",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/scripts/start-ntp-web.ps1\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
